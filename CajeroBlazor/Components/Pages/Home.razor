@page "/"

<PageTitle>Cajero Automático</PageTitle>

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4">🏦Banco de los Universitarios</h1>
        <p class="lead text-muted">Sistema de gestión bancaria</p>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-3">
            <a href="cuentahabientes" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100 border-primary">
                    <div class="card-body py-4">
                        <div class="fs-1">👤</div>
                        <h5 class="card-title mt-2">Cuentahabientes</h5>
                        <p class="card-text text-muted small">Registrar y consultar clientes</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="cuentas" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100 border-success">
                    <div class="card-body py-4">
                        <div class="fs-1">🏦</div>
                        <h5 class="card-title mt-2">Cuentas</h5>
                        <p class="card-text text-muted small">Abrir y consultar cuentas</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="tarjetas" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100 border-warning">
                    <div class="card-body py-4">
                        <div class="fs-1">💳</div>
                        <h5 class="card-title mt-2">Tarjetas</h5>
                        <p class="card-text text-muted small">Emitir tarjetas bancarias</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="transacciones" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100 border-info">
                    <div class="card-body py-4">
                        <div class="fs-1">💸</div>
                        <h5 class="card-title mt-2">Transacciones</h5>
                        <p class="card-text text-muted small">Depósitos, créditos y débitos</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="bitacora" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100 border-secondary">
                    <div class="card-body py-4">
                        <div class="fs-1">📋</div>
                        <h5 class="card-title mt-2">Bitácora</h5>
                        <p class="card-text text-muted small">Historial de movimientos</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="transacciones-masivas" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100 border-dark">
                    <div class="card-body py-4">
                        <div class="fs-1">⚡</div>
                        <h5 class="card-title mt-2">Masivas</h5>
                        <p class="card-text text-muted small">Procesar lotes desde archivo</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
