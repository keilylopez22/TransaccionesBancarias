@page "/bitacora"
@rendermode InteractiveServer
@inject CajeroBlazor.Services.ApiService Api

<PageTitle>Bitácora</PageTitle>

<div class="container mt-4">
    <h2>📋 Bitácora de Transacciones</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">Filtros de búsqueda</div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Número de Cuenta</label>
                    <input class="form-control" @bind="numeroCuenta" placeholder="Ej: 1000000001" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tipo Transacción</label>
                    <select class="form-select" @bind="idTipoTransaccion">
                        <option value="">Todos</option>
                        <option value="1">Depósito</option>
                        <option value="2">Pago de Cheque</option>
                        <option value="3">Nota de Credito</option>
                        <option value="4">Nota de Debito</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Desde</label>
                    <input type="date" class="form-control" @bind="fechaDesde" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Hasta</label>
                    <input type="date" class="form-control" @bind="fechaHasta" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select class="form-select" @bind="soloExitosos">
                        <option value="">Todos</option>
                        <option value="true">Exitosos</option>
                        <option value="false">Fallidos</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button class="btn btn-primary w-100" @onclick="Buscar" disabled="@cargando">
                        @(cargando ? "..." : "🔍")
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (movimientos == null)
    {
        <p class="text-muted">Ingresa un número de cuenta o aplica filtros y haz clic en 🔍 para buscar.</p>
    }
    else if (!movimientos.Any())
    {
        <div class="alert alert-info">No se encontraron movimientos con los filtros aplicados.</div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">@movimientos.Count movimiento(s) encontrado(s)</span>
            <div>
                <span class="badge bg-success me-1">✅ Exitosos: @movimientos.Count(m => m.Exito)</span>
                <span class="badge bg-danger">❌ Fallidos: @movimientos.Count(m => !m.Exito)</span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Fecha</th>
                        <th>Cuenta</th>
                        <th>Tipo</th>
                        <th class="text-end">Monto</th>
                        <th class="text-end">Saldo Anterior</th>
                        <th class="text-end">Saldo Nuevo</th>
                        <th>Usuario</th>
                        <th>Detalle</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in movimientos)
                    {
                        <tr class="@(!m.Exito ? "table-danger" : "")">
                            <td><small>@m.Id</small></td>
                            <td><small>@m.FechaMovimiento.ToString("dd/MM/yyyy HH:mm")</small></td>
                            <td><code class="small">@m.NumeroCuenta</code></td>
                            <td>
                                <span class="badge @BadgeTipo(m.IdTipoTransaccion)">
                                    @m.TipoTransaccion
                                </span>
                            </td>
                            <td class="text-end fw-bold @(m.IdTipoTransaccion == 4 || m.IdTipoTransaccion == 2 ? "text-danger" : "text-success")">
                                Q @m.Monto.ToString("N2")
                            </td>
                            <td class="text-end"><small>Q @m.SaldoAnterior.ToString("N2")</small></td>
                            <td class="text-end"><small>Q @m.SaldoNuevo.ToString("N2")</small></td>
                            <td><small>@(m.Usuario ?? "-")</small></td>
                            <td>
                                @if (!string.IsNullOrEmpty(m.Detalle))
                                {
                                    <span title="@m.Detalle" style="cursor:help">
                                        <small>@(m.Detalle.Length > 30 ? m.Detalle[..30] + "…" : m.Detalle)</small>
                                    </span>
                                }
                            </td>
                            <td>
                                @if (m.Exito)
                                {
                                    <span class="badge bg-success">✅</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">❌</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private string numeroCuenta = "";
    private string idTipoTransaccion = "";
    private string soloExitosos = "";
    private DateTime? fechaDesde;
    private DateTime? fechaHasta;
    private List<CajeroBlazor.Models.BitacoraTransaccion>? movimientos;
    private bool cargando;

    private async Task Buscar()
    {
        cargando = true;
        movimientos = null;

        if (!string.IsNullOrWhiteSpace(numeroCuenta))
        {
            movimientos = await Api.GetBitacoraAsync(numeroCuenta.Trim(), fechaDesde, fechaHasta);
        }
        else
        {
            int? tipo = int.TryParse(idTipoTransaccion, out var t) ? t : null;
            bool? exitosos = soloExitosos == "true" ? true : soloExitosos == "false" ? false : null;
            movimientos = await Api.GetBitacoraFiltradaAsync(idTipoTransaccion: tipo, soloExitosos: exitosos);
        }

        cargando = false;
    }

    private static string BadgeTipo(int tipo) => tipo switch
    {
        1 => "bg-primary",
        2 => "bg-danger",
        3 => "bg-info text-dark",
        4 => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
